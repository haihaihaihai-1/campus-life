.simukraft_panel {
  background: built-in(ui-mc:BORDER);
  padding-all: 10;
}

.simukraft_shell_panel {
  background: rect(#ff444444);
}

.simukraft_badge {
  background: built-in(ui-mc:RECT_2);
}

.simukraft_grid_panel {
  background: group(rect(#44202020), built-in(ui-mc:BORDER));
  padding-all: 8;
}

.simukraft_card_shadow {
  background: rect(#88000000);
}

.simukraft_card_content_panel {
  background: rect(#28ffffff);
}

.simukraft_card_slot {
  background: built-in(ui-mc:RECT_2);
}

button.simukraft_large_button:host {
  base-background: built-in(ui-mc:RECT_BORDER);
  hover-background: built-in(ui-mc:RECT_3);
  pressed-background: built-in(ui-mc:RECT_3) color(#dddddd);
  padding-all: 6;
}

button.simukraft_large_button:disabled:host {
  base-background: built-in(ui-mc:RECT_2);
}

button.simukraft_card_button:host {
  base-background: built-in(ui-mc:RECT_3);
  hover-background: built-in(ui-mc:RECT_3);
  pressed-background: built-in(ui-mc:RECT_3) color(#dddddd);
}
