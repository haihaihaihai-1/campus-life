.campuslife_panel {
  background: sprite(campuslife:textures/gui/ore_styles.png, 128, 128, 128, 128, 3, 3, 3, 5);
  padding-all: 10;
}

.campuslife_shell_panel {
  background: rect(#80000000);
}

.campuslife_badge {
  background: sprite(campuslife:textures/gui/ore_styles.png, 24, 0, 3, 5, 1, 3, 1, 1);
}

.campuslife_grid_panel {
  background: group(rect(#44202020), sprite(campuslife:textures/gui/ore_styles.png, 128, 128, 128, 128, 3, 3, 3, 5));
  padding-all: 8;
}

.campuslife_card_shadow {
  background: rect(#88000000);
}

.campuslife_card_content_panel {
  background: group(rect(#22ffffff), sprite(campuslife:textures/gui/ore_styles.png, 21, 0, 3, 4, 1, 1, 1, 2));
}

.campuslife_card_slot {
  background: sprite(campuslife:textures/gui/ore_styles.png, 15, 0, 3, 3, 1, 1, 1, 1);
}

button:host {
  base-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 0, 5, 7, 2, 2, 2, 4);
  hover-background: sprite(campuslife:textures/gui/ore_styles.png, 5, 0, 5, 7, 2, 2, 2, 4);
  pressed-background: sprite(campuslife:textures/gui/ore_styles.png, 5, 0, 5, 7, 2, 2, 2, 4) color(#dddddd);
}

button:disabled:host {
  base-background: sprite(campuslife:textures/gui/ore_styles.png, 10, 0, 5, 7, 2, 2, 2, 4);
}

button.campuslife_large_button:host {
  base-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 7, 13, 14, 2, 2, 2, 3);
  hover-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 35, 13, 14, 2, 2, 2, 3);
  pressed-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 35, 13, 14, 2, 2, 2, 3) color(#dddddd);
  padding-all: 6;
  padding-bottom: 7;
}

button.campuslife_large_button:disabled:host {
  base-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 21, 13, 14, 2, 2, 2, 3);
}

button.campuslife_card_button:host {
  base-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 35, 13, 14, 2, 2, 2, 3);
  hover-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 35, 13, 14, 2, 2, 2, 3);
  pressed-background: sprite(campuslife:textures/gui/ore_styles.png, 0, 35, 13, 14, 2, 2, 2, 3) color(#dddddd);
}
